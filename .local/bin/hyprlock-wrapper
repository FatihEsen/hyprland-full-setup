BRIGHTNESS_FILE="${XDG_RUNTIME_DIR:-/tmp}/hyprlock-brightness.txt"
PLAYERS_FILE="${XDG_RUNTIME_DIR:-/tmp}/hyprlock-playing-players.txt"

notify_user() {
    local summary="$1" body="$2" urgency="${3:-low}" timeout="${4:-2000}"
    notify-send --app-name="Hyprlock" --urgency="$urgency" --expire-time="$timeout" "$summary" "$body"
}

# --- 1. Durumları Kaydet ---
# Eğer dosya zaten varsa (zaten kilitliyse), mevcut parlaklığı bozmamak için üzerine yazmıyoruz.
if [ ! -f "$BRIGHTNESS_FILE" ]; then
    CURRENT_VAL=$(brightnessctl get)
    MAX_VAL=$(brightnessctl max)
    # Eğer parlaklık %20'den azsa, muhtemelen hypridle kısmıştır. 
    # Bu durumda kilit açılınca tam parlaklığa dönmesi için MAX_VAL kaydediyoruz.
    if [ "$CURRENT_VAL" -lt $((MAX_VAL / 5)) ]; then
        echo "$MAX_VAL" > "$BRIGHTNESS_FILE"
    else
        echo "$CURRENT_VAL" > "$BRIGHTNESS_FILE"
    fi
fi

# Çalan medya oynatıcılarını kaydet
{
    > "$PLAYERS_FILE"
    while IFS= read -r player; do
        if [[ "$(playerctl -p "$player" status 2>/dev/null)" == "Playing" ]]; then
            echo "$player" >> "$PLAYERS_FILE"
            # Müzik devam etsin dosyası yoksa durdur
            if [ ! -f /tmp/hyprlock-keep-music ]; then
                playerctl -p "$player" pause 2>/dev/null
            fi
        fi
    done < <(playerctl --list-all 2>/dev/null | grep -v '^$')
    
    # MPV özel kontrolü (socket varsa)
    if [ ! -f /tmp/hyprlock-keep-music ] && [ -S /tmp/mpvsocket ]; then
        echo '{ "command": ["set", "pause", true] }' | socat - /tmp/mpvsocket 2>/dev/null
    fi
} &>/dev/null

# --- 2. Kilit Öncesi Hazırlık ---
# Parlaklığı %10'a düşür
brightnessctl set 10% &>/dev/null

# Bildirim (Buradaki satır sonu hatası düzeltildi)
notify_user "🌙🔒 Kilitleniyor" "Medya durduruldu, parlaklık düşürüldü." "normal" 2000

# Hypridle zamanlayıcısını resetlemek için DPMS'i uyandırıyoruz
hyprctl dispatch dpms on 2>/dev/null || true
sleep 0.1

# --- 3. Kilitleme ---
hyprlock

# --- 4. Kilit Açılınca Geri Yükle ---
{
    # ÖNCE ekranı uyandırıyoruz (Sıralama önemli: Ekran uyanmadan parlaklık komutu bazen işlemez)
    hyprctl dispatch dpms on 2>/dev/null || true
    sleep 0.2

    # Parlaklığı geri yükle (Ham değerle set ederek hassasiyeti koruyoruz)
    if [ -f "$BRIGHTNESS_FILE" ]; then
        SAVED_VAL=$(cat "$BRIGHTNESS_FILE")
        if [ -n "$SAVED_VAL" ]; then
            brightnessctl set "$SAVED_VAL" &>/dev/null
        fi
        rm -f "$BRIGHTNESS_FILE"
    fi

    # Medyayı geri başlat
    restarted=0
    if [ -s "$PLAYERS_FILE" ]; then
        while IFS= read -r player; do
            playerctl -p "$player" play 2>/dev/null && ((restarted++))
        done < "$PLAYERS_FILE"
        rm -f "$PLAYERS_FILE"
    fi

    # Bildirim
    if (( restarted > 0 )); then
        notify_user "🌞🔊 Devam Ediyor" "Parlaklık ve $restarted oynatıcı geri yüklendi." "normal" 2500
    else
        notify_user "🌞 Hoş Geldiniz" "Parlaklık geri yüklendi." "normal" 2000
    fi
} &>/dev/null

