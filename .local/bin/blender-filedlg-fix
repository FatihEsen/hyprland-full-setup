#!/usr/bin/env python3
"""
Hyprland Blender File View düzeltici
Blender'ın dosya açma penceresi açıldığında onu %80 boyuta getirip ortalar.
"""

import os
import socket
import subprocess
import threading
import time
import json


def get_monitor_size():
    result = subprocess.run(
        ["hyprctl", "monitors", "-j"],
        capture_output=True, text=True
    )
    monitors = json.loads(result.stdout)
    if monitors:
        m = monitors[0]
        return m["width"], m["height"]
    return 1920, 1080


def fix_window(addr_hex):
    """0.3 saniye bekleyip pencereyi büyüt"""
    time.sleep(0.3)

    full_addr = f"0x{addr_hex}"
    result = subprocess.run(
        ["hyprctl", "clients", "-j"],
        capture_output=True, text=True
    )
    clients = json.loads(result.stdout)

    win = next((c for c in clients if c["address"] == full_addr), None)
    if not win:
        return

    if win["class"] == "blender" and win["title"] == "Blender File View":
        mw, mh = get_monitor_size()
        tw = mw * 80 // 100
        th = mh * 80 // 100
        tx = (mw - tw) // 2
        ty = (mh - th) // 2

        subprocess.run(["hyprctl", "--quiet", "dispatch", "setfloating", f"address:{full_addr}"])
        time.sleep(0.05)
        subprocess.run(["hyprctl", "--quiet", "dispatch",
                        "resizewindowpixel", f"exact {tw} {th},address:{full_addr}"])
        subprocess.run(["hyprctl", "--quiet", "dispatch",
                        "movewindowpixel", f"exact {tx} {ty},address:{full_addr}"])


def main():
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE", "")

    if not sig:
        # İmzayı otomatik bul
        hypr_dir = f"{runtime_dir}/hypr"
        try:
            entries = os.listdir(hypr_dir)
            if entries:
                sig = entries[0]
        except FileNotFoundError:
            print("Hyprland klasörü bulunamadı!")
            return

    sock_path = f"{runtime_dir}/hypr/{sig}/.socket2.sock"
    print(f"Bağlanılar: {sock_path}")

    while True:
        try:
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.connect(sock_path)
            buf = ""
            while True:
                data = sock.recv(4096).decode("utf-8", errors="replace")
                if not data:
                    break
                buf += data
                while "\n" in buf:
                    line, buf = buf.split("\n", 1)
                    line = line.strip()
                    if line.startswith("openwindow>>"):
                        # Format: openwindow>>addr,ws,class,title
                        payload = line[len("openwindow>>"):]
                        parts = payload.split(",", 3)
                        if parts:
                            addr = parts[0]
                            t = threading.Thread(target=fix_window, args=(addr,), daemon=True)
                            t.start()
        except Exception as e:
            print(f"Bağlantı hatası: {e}, 3 saniye sonra tekrar denenecek...")
            time.sleep(3)


if __name__ == "__main__":
    main()
